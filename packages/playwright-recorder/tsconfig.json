{
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["es2023"],
    "moduleResolution": "Node",
    "downlevelIteration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",
  }
}
